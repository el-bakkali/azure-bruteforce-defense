{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "uksouth"
    },
    "adminUsername": {
      "value": "azuredefender"
    },
    "adminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<vault-name>"
        },
        "secretName": "vm-admin-password"
      }
    },
    "openAiDeployment": {
      "value": "gpt-4o-mini"
    },
    "openAiModelName": {
      "value": "gpt-4o-mini"
    },
    "openAiCapacity": {
      "value": 10
    }
  }
}
